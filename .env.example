# Copy to .env.local for local dev. On Vercel, set VITE_API_BASE_URL in
# Project Settings → Environment Variables (do NOT commit real .env files).
#
# Base URL of the frikkinwave backend API, WITHOUT a trailing slash.
#   local dev    : http://localhost:8000
#   production   : https://api.frikkinwave.com
VITE_API_BASE_URL=https://api.frikkinwave.com
